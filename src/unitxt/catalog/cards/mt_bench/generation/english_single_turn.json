{
    "__type__": "unitxt.card.TaskCard",
    "loader": {
        "__type__": "unitxt.loaders.LoadHF",
        "path": "dim/mt_bench_en",
        "split": "train"
    },
    "preprocess_steps": [
        {
            "__type__": "unitxt.splitters.RenameSplits",
            "mapper": {
                "train": "test"
            }
        },
        {
            "__type__": "unitxt.operators.Copy",
            "field": "turns/0",
            "to_field": "turns"
        },
        {
            "__type__": "unitxt.operators.Rename",
            "field_to_field": {
                "turns": "input",
                "category": "group"
            }
        },
        {
            "__type__": "unitxt.operators.Set",
            "fields": {
                "output": "None",
                "type_of_input": "question",
                "type_of_output": "answer"
            }
        }
    ],
    "task": "tasks.generation",
    "templates": [
        "templates.empty"
    ]
}
