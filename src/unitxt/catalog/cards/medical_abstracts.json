{
    "__type__": "unitxt.card.TaskCard",
    "loader": {
        "__type__": "unitxt.loaders.LoadCSV",
        "files": {
            "train": "https://raw.githubusercontent.com/sebischair/Medical-Abstracts-TC-Corpus/main/medical_tc_train.csv",
            "test": "https://raw.githubusercontent.com/sebischair/Medical-Abstracts-TC-Corpus/main/medical_tc_test.csv"
        }
    },
    "preprocess_steps": [
        {
            "__type__": "unitxt.splitters.SplitRandomMix",
            "mix": {
                "train": "train[90%]",
                "validation": "train[10%]",
                "test": "test"
            }
        },
        {
            "__type__": "unitxt.operators.Rename",
            "field_to_field": {
                "medical_abstract": "text",
                "condition_label": "label"
            }
        },
        {
            "__type__": "unitxt.operators.MapInstanceValues",
            "mappers": {
                "label": {
                    "1": "neoplasms",
                    "2": "digestive system diseases",
                    "3": "nervous system diseases",
                    "4": "cardiovascular diseases",
                    "5": "general pathological conditions"
                }
            }
        },
        {
            "__type__": "unitxt.operators.Set",
            "fields": {
                "classes": [
                    "neoplasms",
                    "digestive system diseases",
                    "nervous system diseases",
                    "cardiovascular diseases",
                    "general pathological conditions"
                ],
                "text_type": "abstract"
            }
        }
    ],
    "task": "tasks.classification.multi_class.topic_classification",
    "templates": "templates.classification.multi_class.all"
}
