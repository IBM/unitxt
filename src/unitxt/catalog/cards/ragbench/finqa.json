{
    "__type__": "unitxt.card.TaskCard",
    "loader": {
        "__type__": "unitxt.loaders.LoadHF",
        "path": "rungalileo/ragbench",
        "name": "finqa"
    },
    "preprocess_steps": [
        {
            "__type__": "unitxt.operators.Set",
            "fields": {
                "context_type": "documents"
            }
        },
        {
            "__type__": "unitxt.collections_operators.Wrap",
            "field": "documents",
            "inside": "list",
            "process_every_value": true
        },
        {
            "__type__": "unitxt.collections_operators.Dictify",
            "field": "documents",
            "to_field": "context",
            "with_keys": [
                "body"
            ],
            "process_every_value": true
        },
        {
            "__type__": "unitxt.operators.Set",
            "fields": {
                "context/*/title": "Document"
            }
        },
        {
            "__type__": "unitxt.collections_operators.Wrap",
            "field": "response",
            "inside": "list",
            "to_field": "answers"
        }
    ],
    "task": "tasks.qa.with_context",
    "templates": "templates.qa.with_context.all"
}
