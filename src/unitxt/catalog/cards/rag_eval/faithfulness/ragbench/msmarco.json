{
    "__type__": "unitxt.card.TaskCard",
    "loader": {
        "__type__": "unitxt.loaders.LoadHF",
        "path": "rungalileo/ragbench",
        "name": "msmarco",
        "split": "test"
    },
    "preprocess_steps": [
        {
            "__type__": "unitxt.operators.Copy",
            "field": "response",
            "to_field": "answer"
        },
        {
            "__type__": "unitxt.operators.Copy",
            "field": "documents",
            "to_field": "contexts"
        },
        {
            "__type__": "unitxt.operators.ExecuteExpression",
            "expression": "int(adherence_score)",
            "to_field": "number_val"
        },
        {
            "__type__": "unitxt.operators.ExecuteExpression",
            "expression": "['yes' if adherence_score else 'no']",
            "to_field": "is_faithful"
        }
    ],
    "task": "tasks.rag_eval.faithfulness.binary",
    "templates": {
        "default": {
            "__type__": "unitxt.templates.NullTemplate"
        }
    }
}
