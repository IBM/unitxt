{
    "__type__": "unitxt.card.TaskCard",
    "loader": {
        "__type__": "unitxt.loaders.LoadHF",
        "path": "lmms-lab/ChartQA"
    },
    "preprocess_steps": [
        {
            "__type__": "unitxt.operators.Shuffle"
        },
        {
            "__type__": "unitxt.collections_operators.Wrap",
            "field": "answer",
            "inside": "list",
            "to_field": "answers"
        },
        {
            "__type__": "unitxt.image_operators.ToImage",
            "field": "image",
            "to_field": "context"
        },
        {
            "__type__": "unitxt.operators.Set",
            "fields": {
                "context_type": "image"
            }
        }
    ],
    "task": "tasks.qa.with_context.with_type[metrics=[metrics.relaxed_correctness]]",
    "templates": [
        "templates.qa.with_context.chart_qa",
        "templates.qa.with_context",
        "templates.qa.extractive",
        "templates.qa.with_context.simple",
        "templates.qa.with_context.simple2",
        "templates.qa.with_context.with_type",
        "templates.qa.with_context.question_first",
        "templates.qa.with_context.ffqa",
        "templates.qa.with_context.title",
        "templates.qa.with_context.lmms_eval"
    ],
    "__tags__": {
        "license": "GPL-3.0",
        "multilinguality": "monolingual",
        "modalities": [
            "image",
            "text"
        ],
        "size_categories": "10K<n<100K",
        "task_categories": "question-answering",
        "task_ids": "extractive-qa"
    },
    "__description__": "ChartQA: A Benchmark for Question Answering about Charts with Visual and Logical Reasoning."
}
