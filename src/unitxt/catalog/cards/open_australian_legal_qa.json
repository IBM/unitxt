{
    "__type__": "unitxt.card.TaskCard",
    "loader": {
        "__type__": "unitxt.loaders.LoadHF",
        "path": "umarbutler/open-australian-legal-qa",
        "name": "default"
    },
    "preprocess_steps": [
        {
            "__type__": "unitxt.splitters.SplitRandomMix",
            "mix": {
                "train": "train[0.5]",
                "validation": "train[0.2]",
                "test": "train[0.3]"
            }
        },
        {
            "__type__": "unitxt.operators.Shuffle"
        },
        {
            "__type__": "unitxt.operators.Set",
            "fields": {
                "context_type": "legal document"
            }
        },
        {
            "__type__": "unitxt.operators.Copy",
            "field": "source/text",
            "to_field": "context/body"
        },
        {
            "__type__": "unitxt.operators.Copy",
            "field": "source/citation",
            "to_field": "context/title"
        },
        {
            "__type__": "unitxt.collections_operators.Wrap",
            "field": "answer",
            "inside": "list",
            "to_field": "answers"
        }
    ],
    "task": "tasks.qa.with_context",
    "templates": "templates.qa.with_context.all"
}
