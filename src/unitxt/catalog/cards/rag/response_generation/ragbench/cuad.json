{
    "__type__": "unitxt.card.TaskCard",
    "loader": {
        "__type__": "unitxt.loaders.LoadHF",
        "path": "rungalileo/ragbench",
        "name": "cuad"
    },
    "preprocess_steps": [
        {
            "__type__": "unitxt.operators.Copy",
            "field": "documents",
            "to_field": "contexts"
        },
        {
            "__type__": "unitxt.operators.Copy",
            "field": "documents",
            "to_field": "contexts_ids"
        },
        {
            "__type__": "unitxt.collections_operators.Wrap",
            "field": "response",
            "inside": "list",
            "to_field": "reference_answers"
        }
    ],
    "task": "tasks.rag.response_generation",
    "templates": {
        "default": "templates.rag.response_generation.please_respond_chat"
    }
}
