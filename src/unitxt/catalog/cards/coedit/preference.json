{
    "__type__": "unitxt.card.TaskCard",
    "loader": {
        "__type__": "unitxt.loaders.LoadHF",
        "path": "grammarly/coedit",
        "streaming": true
    },
    "preprocess_steps": [
        {
            "__type__": "unitxt.operators.Shuffle",
            "page_size": 9223372036854775807
        },
        "splitters.small_no_test",
        {
            "__type__": "unitxt.string_operators.Split",
            "field": "src",
            "by": ": "
        },
        {
            "__type__": "unitxt.collections_operators.Slice",
            "field": "src",
            "start": 1
        },
        {
            "__type__": "unitxt.operators.Copy",
            "field": "src/0",
            "to_field": "instruction"
        },
        {
            "__type__": "unitxt.string_operators.Join",
            "field": "src",
            "by": ": "
        },
        {
            "__type__": "unitxt.operators.ListFieldValues",
            "fields": [
                "tgt",
                "src"
            ],
            "to_field": "choices"
        },
        {
            "__type__": "unitxt.operators.ShuffleFieldValues",
            "field": "choices"
        },
        {
            "__type__": "unitxt.operators.Set",
            "fields": {
                "output_type": "sentence",
                "input_type": "sentence"
            }
        },
        {
            "__type__": "unitxt.operators.Rename",
            "field": "src",
            "to_field": "input"
        },
        {
            "__type__": "unitxt.operators.IndexOf",
            "search_in": "choices",
            "index_of": "tgt",
            "to_field": "output_choice"
        }
    ],
    "task": "tasks.evaluation.preference",
    "templates": "templates.evaluation.preference.all",
    "__tags__": {
        "arxiv": "2305.09857",
        "language": "en",
        "license": "apache-2.0",
        "region": "us",
        "size_categories": "10K<n<100K",
        "task_categories": "text-generation"
    },
    "__description__": "This is the dataset that was used to train the CoEdIT text editing models. Full details of the dataset can be found in our paper… See the full description on the dataset page: https://huggingface.co/datasets/grammarly/coedit."
}
