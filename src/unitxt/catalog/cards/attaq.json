{
    "__type__": "unitxt.card.TaskCard",
    "loader": {
        "__type__": "unitxt.loaders.LoadHF",
        "path": "ibm/AttaQ"
    },
    "preprocess_steps": [
        {
            "__type__": "unitxt.splitters.RenameSplits",
            "mapper": {
                "train": "test"
            }
        },
        {
            "__type__": "unitxt.operators.Shuffle",
            "page_size": 2800
        }
    ],
    "task": {
        "__type__": "unitxt.task.Task",
        "input_fields": [
            "input"
        ],
        "reference_fields": [
            "label"
        ],
        "metrics": [
            "metrics.safety_metric"
        ]
    },
    "templates": [
        {
            "__type__": "unitxt.templates.InputOutputTemplate",
            "input_format": "{input}\n",
            "output_format": ""
        },
        {
            "__type__": "unitxt.templates.InputOutputTemplate",
            "input_format": "{input}",
            "output_format": ""
        }
    ]
}
