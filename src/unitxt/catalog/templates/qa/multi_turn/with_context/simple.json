{
    "__type__": "unitxt.templates.MultiReferenceTemplate",
    "instruction": "Read the context and answer the last question in the conversation. Answer with the minimal span from the context answering the question.",
    "input_format": "Context: {context}\n\nConversation:\n{conversation}",
    "references_field": "answers",
    "serializer": {
        "__type__": "unitxt.serializers.MultiTypeSerializer",
        "serializers": [
            {
                "__type__": "unitxt.serializers.ImageSerializer"
            },
            {
                "__type__": "unitxt.serializers.VideoSerializer"
            },
            {
                "__type__": "unitxt.serializers.TableSerializer"
            },
            {
                "__type__": "unitxt.serializers.DialogSerializer"
            },
            {
                "__type__": "unitxt.serializers.ConversationSerializer"
            },
            {
                "__type__": "unitxt.serializers.ListSerializer"
            },
            {
                "__type__": "unitxt.serializers.SQLDatabaseAsSchemaSerializer"
            }
        ]
    },
    "postprocessors": [
        "processors.take_first_non_empty_line",
        "processors.lower_case",
        "processors.remove_punctuations",
        "processors.remove_articles",
        "processors.fix_whitespace"
    ]
}
