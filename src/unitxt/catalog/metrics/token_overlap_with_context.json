{
    "__type__": "unitxt.metrics.MetricPipeline",
    "main_score": "f1",
    "preprocess_steps": [
        {
            "__type__": "unitxt.operators.Copy",
            "field": "task_data/context",
            "to_field": "references"
        },
        {
            "__type__": "unitxt.operators.ListFieldValues",
            "fields": [
                "references"
            ],
            "to_field": "references"
        }
    ],
    "metric": {
        "__type__": "unitxt.metrics.TokenOverlap"
    },
    "postprocess_steps": [
        {
            "__type__": "unitxt.operators.Copy",
            "field_to_field": [
                [
                    "score/global/f1",
                    "score/global/f1_overlap_with_context"
                ],
                [
                    "score/global/recall",
                    "score/global/recall_overlap_with_context"
                ],
                [
                    "score/global/precision",
                    "score/global/precision_overlap_with_context"
                ]
            ]
        }
    ]
}
