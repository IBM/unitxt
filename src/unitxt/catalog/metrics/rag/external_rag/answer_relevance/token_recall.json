{
    "__type__": "unitxt.metrics.MetricPipeline",
    "main_score": "recall",
    "preprocess_steps": [
        {
            "__type__": "unitxt.operators.Copy",
            "field": "prediction/answer",
            "to_field": "prediction"
        },
        {
            "__type__": "unitxt.collections_operators.Wrap",
            "field": "task_data/question",
            "inside": "list",
            "to_field": "references"
        }
    ],
    "metric": "metrics.token_overlap",
    "score_prefix": "answer_relevance_token_recall_"
}
