{
    "__type__": "unitxt.metrics.MetricPipeline",
    "main_score": "reward_score",
    "preprocess_steps": [
        {
            "__type__": "unitxt.collections_operators.Wrap",
            "field": "task_data/question",
            "inside": "list",
            "to_field": "references"
        },
        {
            "__type__": "unitxt.serializers.MultiTypeSerializer",
            "field": "references",
            "process_every_value": true
        }
    ],
    "metric": "metrics.reward.deberta_v3_large_v2",
    "score_prefix": "answer_relevance_"
}
