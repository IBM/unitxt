{
    "__type__": "unitxt.metrics.MetricPipeline",
    "main_score": "score",
    "preprocess_steps": [
        {
            "__type__": "unitxt.operators.Copy",
            "field_to_field": [
                [
                    "prediction/contexts",
                    "references"
                ]
            ]
        },
        {
            "__type__": "unitxt.operators.Copy",
            "field_to_field": [
                [
                    "task_data/question",
                    "prediction"
                ]
            ]
        },
        {
            "__type__": "unitxt.serializers.MultiTypeSerializer",
            "field": "prediction"
        }
    ],
    "metric": "metrics.perplexity_q.flan_t5_small[score_prefix=context_relevance_]"
}
