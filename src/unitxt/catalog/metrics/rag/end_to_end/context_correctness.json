{
    "__type__": "unitxt.metrics.MetricPipeline",
    "main_score": "score",
    "preprocess_steps": [
        {
            "__type__": "unitxt.operators.Copy",
            "field_to_field": [
                [
                    "prediction/context_ids",
                    "prediction"
                ]
            ]
        },
        {
            "__type__": "unitxt.operators.ListFieldValues",
            "fields": [
                "task_data/reference_context_ids"
            ],
            "to_field": "references"
        }
    ],
    "metric": "metrics.mrr[score_prefix=context_correctness_]"
}
