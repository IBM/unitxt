{
    "__type__": "unitxt.metrics.MetricPipeline",
    "main_score": "score",
    "preprocess_steps": [
        {
            "__type__": "unitxt.operators.Copy",
            "field_to_field": [
                [
                    "prediction/answer",
                    "prediction"
                ]
            ]
        },
        {
            "__type__": "unitxt.operators.ListFieldValues",
            "fields": [
                "task_data/question"
            ],
            "to_field": "references"
        },
        {
            "__type__": "unitxt.serializers.MultiTypeSerializer",
            "field": "references",
            "process_every_value": true
        }
    ],
    "metric": "metrics.reward.deberta_v3_large_v2[score_prefix=answer_reward_]"
}
