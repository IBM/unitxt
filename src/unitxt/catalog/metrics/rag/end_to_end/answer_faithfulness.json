{
    "__type__": "unitxt.metrics.MetricPipeline",
    "main_score": "precision",
    "preprocess_steps": [
        {
            "__type__": "unitxt.operators.Copy",
            "field_to_field": [
                [
                    "prediction/contexts",
                    "references"
                ]
            ]
        },
        {
            "__type__": "unitxt.operators.Copy",
            "field_to_field": [
                [
                    "prediction/answer",
                    "prediction"
                ]
            ]
        }
    ],
    "metric": "metrics.token_overlap[score_prefix=answer_faithfulness_]"
}
