{
    "__type__": "unitxt.metrics.MetricPipeline",
    "main_score": "granite_guardian_context_relevance",
    "metric": {
        "__type__": "unitxt.metrics.GraniteGuardianRagRisk",
        "main_score": "granite_guardian_context_relevance",
        "risk_name": "context_relevance",
        "user_message_field": "question",
        "assistant_message_field": "answer"
    },
    "preprocess_steps": [
        {
            "__type__": "unitxt.string_operators.Join",
            "field": "contexts",
            "by": "\n"
        },
        {
            "__type__": "unitxt.operators.Copy",
            "field_to_field": {
                "ground_truths": "task_data/ground_truths",
                "answer": "task_data/answer",
                "contexts": "task_data/context",
                "question": "task_data/question"
            },
            "not_exist_do_nothing": true
        },
        {
            "__type__": "unitxt.operators.Copy",
            "field_to_field": {
                "prediction": "task_data/question"
            },
            "not_exist_do_nothing": true
        },
        {
            "__type__": "unitxt.operators.Set",
            "fields": {
                "prediction": 0.0,
                "references": [
                    0.0
                ]
            }
        }
    ]
}
